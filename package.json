{
  "name": "roder-opentui",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/ws": "^8.18.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@opentui/core": "^0.2.16",
    "commander": "^14.0.3",
    "ws": "^8.21.0"
  },
  "scripts": {
    "start": "bun run index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "bundle:roder": "node scripts/bundle-roder.mjs",
    "start:remote": "bun run index.ts --transport remote",
    "start:embedded": "bun run index.ts --transport embedded"
  },
  "bin": {
    "roder-opentui": "./index.ts"
  }
}
